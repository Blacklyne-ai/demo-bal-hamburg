---
// WhatsApp Floating Widget - dauerhaft sichtbar rechts unten (mobile + desktop).
// Brand-Grün #25D366 mit subtle Pulse-Glow. Klick öffnet wa.me Direct-Chat.
import { whatsappLink, site } from '../data/site';
---

<a
  href={whatsappLink}
  target="_blank"
  rel="noopener"
  class="wa-widget"
  aria-label={`WhatsApp-Chat starten mit ${site.shortName}`}
>
  <span class="wa-widget-pulse" aria-hidden="true"></span>
  <svg class="wa-widget-icon" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path fill="currentColor" d="M16.003 0C7.171 0 0 7.17 0 15.998 0 18.804.737 21.54 2.139 23.95L.058 32l8.235-2.166a15.96 15.96 0 0 0 7.71 1.96h.007C24.832 31.794 32 24.624 32 15.799 32 11.515 30.336 7.48 27.314 4.46 24.292 1.437 20.258.003 16.003 0Zm0 29.064h-.005a13.276 13.276 0 0 1-6.756-1.85l-.484-.288-5.011 1.318 1.337-4.892-.315-.502a13.27 13.27 0 0 1-2.026-7.06c.005-7.343 5.978-13.31 13.32-13.31 3.559 0 6.902 1.385 9.413 3.9a13.232 13.232 0 0 1 3.895 9.412c-.003 7.344-5.978 13.31-13.318 13.31Zm7.305-9.964c-.4-.2-2.366-1.166-2.734-1.3-.366-.133-.633-.2-.9.2-.265.4-1.034 1.3-1.267 1.567-.234.266-.467.3-.867.1-.4-.2-1.69-.624-3.22-1.99-1.19-1.062-1.993-2.373-2.226-2.773-.234-.4-.025-.617.175-.815.18-.18.4-.467.6-.7.2-.234.265-.4.4-.667.133-.267.067-.5-.033-.7-.1-.2-.9-2.166-1.234-2.966-.325-.78-.655-.675-.9-.687a16.93 16.93 0 0 0-.767-.014c-.266 0-.7.1-1.066.5-.367.4-1.4 1.367-1.4 3.334s1.434 3.866 1.633 4.133c.2.267 2.823 4.31 6.84 6.043a23.005 23.005 0 0 0 2.282.843c.96.305 1.832.262 2.523.159.77-.115 2.365-.967 2.7-1.9.333-.934.333-1.734.233-1.9-.1-.167-.367-.267-.766-.467Z"/>
  </svg>
  <span class="wa-widget-label">
    <span class="wa-widget-label-top">WhatsApp</span>
    <span class="wa-widget-label-bottom">Chat starten</span>
  </span>
</a>

<style>
  .wa-widget {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 45;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 1rem 0.55rem 0.55rem;
    background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
    color: #fff;
    border-radius: 999px;
    text-decoration: none;
    box-shadow:
      0 10px 28px -6px rgb(37 211 102 / 0.55),
      0 4px 12px -2px rgb(0 0 0 / 0.2),
      inset 0 1px 0 0 rgb(255 255 255 / 0.22);
    transition: transform 0.22s ease, box-shadow 0.25s ease, filter 0.2s ease;
    isolation: isolate;
  }
  .wa-widget:hover {
    transform: translateY(-2px);
    box-shadow:
      0 14px 34px -6px rgb(37 211 102 / 0.7),
      0 5px 14px -2px rgb(0 0 0 / 0.22),
      inset 0 1px 0 0 rgb(255 255 255 / 0.28);
    filter: saturate(1.08);
  }
  .wa-widget:active { transform: translateY(0); }

  .wa-widget-icon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    color: #fff;
    background: rgb(255 255 255 / 0.16);
    border-radius: 999px;
    padding: 6px;
    position: relative;
    z-index: 1;
  }
  .wa-widget-label {
    display: inline-flex;
    flex-direction: column;
    line-height: 1.05;
    text-align: left;
    position: relative;
    z-index: 1;
    padding-right: 0.15rem;
  }
  .wa-widget-label-top {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.92rem;
    letter-spacing: 0.005em;
  }
  .wa-widget-label-bottom {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    opacity: 0.85;
    letter-spacing: 0.02em;
    margin-top: 1px;
  }

  /* Pulse-Glow Ring */
  .wa-widget-pulse {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    box-shadow: 0 0 0 0 rgb(37 211 102 / 0.55);
    animation: wa-pulse 2.6s ease-out infinite;
    pointer-events: none;
  }
  @keyframes wa-pulse {
    0%   { box-shadow: 0 0 0 0   rgb(37 211 102 / 0.55); }
    70%  { box-shadow: 0 0 0 16px rgb(37 211 102 / 0); }
    100% { box-shadow: 0 0 0 0   rgb(37 211 102 / 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-widget-pulse { animation: none; }
  }

  /* Mobile: Icon-only um Floating-Anruf-Pille nicht zu kollidieren */
  @media (max-width: 639px) {
    .wa-widget {
      padding: 0;
      width: 56px;
      height: 56px;
      justify-content: center;
      bottom: 5rem; /* über dem zentrierten Anrufen-CTA */
      right: 1rem;
    }
    .wa-widget-icon {
      width: 36px;
      height: 36px;
      padding: 7px;
      background: transparent;
    }
    .wa-widget-label { display: none; }
  }
</style>
