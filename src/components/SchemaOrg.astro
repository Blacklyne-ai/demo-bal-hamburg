---
import { site } from '../data/site';
import { services } from '../data/services';

interface Props { schema?: object | null; }
const { schema = null } = Astro.props;

const business = {
  '@context': 'https://schema.org',
  '@type': ['AutomotiveBusiness', 'AutoBodyShop', 'AutoRepair', 'LocalBusiness'],
  '@id': site.url + '#business',
  name: site.name,
  description: site.description,
  url: site.url,
  telephone: '+4940721 7258',
  email: site.email,
  faxNumber: '+4940739 37 219',
  image: site.url + '/images/hero.jpg',
  logo: site.url + '/logo.png',
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  paymentAccepted: ['Cash', 'Debit Card', 'Credit Card', 'Bank Transfer'],
  slogan: site.tagline,
  vatID: site.vatId,
  founder: { '@type': 'Person', name: site.owner },
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    postalCode: site.address.postcode,
    addressCountry: 'DE',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.address.lat,
    longitude: site.address.lng,
  },
  hasMap: site.googleMapsUrl,
  areaServed: [
    { '@type': 'Place', name: 'Hamburg' },
    { '@type': 'Place', name: 'Bergedorf' },
    { '@type': 'Place', name: 'Norddeutschland' },
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '18:00',
    },
  ],
  knowsAbout: [
    'Autolackierung', 'Karosseriebau', 'Spot Repair', 'Richtbankarbeiten',
    'Hohlraumversiegelung', 'Unterbodenschutz', 'Scheibenreparatur',
    'Designlackierung', 'Reparaturlackierung', 'Dellenbeseitigung',
    'PPG Lack', 'Glasurit Lack', 'DEKRA zertifiziert',
  ],
  makesOffer: services.map((s) => ({
    '@type': 'Offer',
    itemOffered: { '@type': 'Service', name: s.title, description: s.short },
  })),
};
---
<script type="application/ld+json" set:html={JSON.stringify(business)} />
{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
