---
import { telLandline, site } from '../data/site';
import Icon from './Icon.astro';
---

<a
  href={telLandline}
  class="fixed bottom-4 left-4 right-4 z-40 btn btn-primary btn-block items-center justify-center gap-2 shadow-lg xl:hidden"
  style="padding-top:0.85rem;padding-bottom:0.85rem;box-shadow:0 12px 30px -10px rgba(15,117,189,0.55);"
  aria-label={`Anrufen ${site.phoneLandline}`}
>
  <Icon name="Phone" size={16} strokeWidth={2.2} />
  <span class="font-bold font-headline tracking-wide">ANRUFEN: {site.phoneLandline}</span>
</a>
