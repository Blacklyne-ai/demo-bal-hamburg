---
import {
  Wrench, Cog, Settings, Settings2, Gauge, Sparkles, Droplets, Layers, Package, Search, Target,
  Phone, PhoneCall, Mail, MapPin, Clock, Camera,
  ArrowRight, ArrowUpRight, ChevronRight, ChevronDown, ChevronUp,
  Menu, X, Check, CircleCheck, CircleDot, CircleAlert,
  Calendar, Car, Truck, Building, ShieldCheck, BadgeCheck, Shield,
  MessageCircle, Navigation, ExternalLink, Play, AlertCircle, Award,
  Paintbrush2, Palette, Pipette, Scan, Flame, Wind, Quote, FileText, AlertTriangle,
  Users, Zap, Pin, Send,
} from '@lucide/astro';

const MAP: Record<string, any> = {
  Wrench, Cog, Settings, Settings2, Gauge, Sparkles, Droplets, Layers, Package, Search, Target,
  Phone, PhoneCall, Mail, MapPin, Clock, Camera,
  ArrowRight, ArrowUpRight, ChevronRight, ChevronDown, ChevronUp,
  Menu, X, Check, CircleCheck, CircleDot, CircleAlert,
  Calendar, Car, Truck, Building, ShieldCheck, BadgeCheck, Shield,
  MessageCircle, Navigation, ExternalLink, Play, AlertCircle, Award,
  Paintbrush2, Palette, Pipette, Scan, Flame, Wind, Quote, FileText, AlertTriangle,
  Users, Zap, Pin, Send,
};

interface Props {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
}
const { name, size = 24, class: className = '', strokeWidth = 1.75 } = Astro.props;
const Cmp = MAP[name] ?? CircleDot;
---
<Cmp size={size} class={className} stroke-width={strokeWidth} />
