---
// DSGVO-konformes Cookie-Banner. Diese statische Site setzt standardmäßig
// keine Tracking-Cookies - Einwilligung wird nur lokal (localStorage) gespeichert.
---
<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[70] p-3 md:p-4 translate-y-full transition-transform duration-500" style="will-change: transform;">
  <div class="container-rd">
    <div class="rounded-2xl p-5 md:p-6 flex flex-col md:flex-row md:items-center gap-4 md:gap-6 shadow-2xl" style="background:#0F1419;border:1px solid rgba(255,255,255,0.1);">
      <div class="flex-1">
        <p class="text-white font-medium text-base mb-1 font-headline">Wir respektieren Ihre Privatsphäre</p>
        <p class="text-white/70 text-sm leading-relaxed">
          Diese Website verwendet nur technisch notwendige Cookies. Es werden keine Tracking- oder Analyse-Cookies gesetzt. Mehr in der <a href="/datenschutz" class="text-brand-sky underline underline-offset-2 hover:text-white">Datenschutzerklärung</a>.
        </p>
      </div>
      <div class="flex gap-2.5 flex-shrink-0">
        <button id="cookie-accept" class="btn btn-primary btn-sm">Verstanden</button>
      </div>
    </div>
  </div>
</div>

<script>
  const KEY = 'bal-hamburg-cookie-consent';
  const banner = document.getElementById('cookie-banner');
  const show = () => banner && (banner.style.transform = 'translateY(0)');
  const hide = () => banner && (banner.style.transform = 'translateY(150%)');

  const stored = (() => { try { return localStorage.getItem(KEY); } catch { return 'dismissed'; } })();
  if (!stored) setTimeout(show, 1200);

  const set = (v: string) => { try { localStorage.setItem(KEY, v); } catch {} hide(); };
  document.getElementById('cookie-accept')?.addEventListener('click', () => set('accepted'));
</script>
