---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { site, telLandline } from '../data/site';
import { equipment } from '../data/services';
---

<Layout title={`Qualität - ${site.name}`} description="DEKRA zertifiziert, moderne Lackier- & Trockenkabine, Spot Repair UV-Trocknung, Farbtonanalyse - unsere Ausstattung im Detail." current="qualitaet">

  <!-- Sub-Hero mit Banner -->
  <section class="subpage-hero">
    <div class="subpage-hero-bg" aria-hidden="true">
      <img src="/images/qualitaet.jpg" alt="" loading="eager" />
      <div class="subpage-hero-overlay"></div>
    </div>
    <div class="subpage-hero-inner">
      <div class="container-rd">
        <div class="max-w-3xl">
          <p class="eyebrow mb-5" style="color:rgb(var(--rgb-accent));"><span>Qualität garantiert</span></p>
          <h1 class="heading-display text-balance mb-5">
            DEKRA zertifiziert. <span style="color:rgb(var(--rgb-brand-sky));">Jährlich geprüft.</span>
          </h1>
          <p class="lead-on-dark max-w-2xl text-pretty">
            Unser Fachbetrieb wird jährlich von der DEKRA geprüft und zertifiziert. So garantieren wir Ihnen besten Service - nachweisbar und transparent.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- DEKRA-Bild + Trust-Section -->
  <section class="section section-paper-deep">
    <div class="container-rd">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center">
        <div class="lg:col-span-5">
          <div class="rounded-2xl overflow-hidden border border-line shadow-xl bg-white p-6">
            <img src="/images/dekra.jpg" alt="DEKRA Zertifikat - Bergedorfer Autolackiererei" class="w-full h-auto" loading="eager" />
          </div>
        </div>
        <div class="lg:col-span-7">
          <p class="eyebrow eyebrow-accent mb-5"><span>Meistergeführter Betrieb</span></p>
          <h2 class="heading-xl text-balance mb-5">
            Drei Säulen einer <span class="accent-brand">soliden Werkstattqualität.</span>
          </h2>
          <ul class="space-y-4 text-ink-soft">
            <li class="flex items-start gap-3">
              <span class="info-card-icon flex-shrink-0" style="width:38px;height:38px;"><Icon name="ShieldCheck" size={18} strokeWidth={1.8} /></span>
              <div>
                <strong class="text-ink font-headline block mb-1">DEKRA Zertifizierung</strong>
                Der Fachbetrieb wird in regelmäßigen Abständen geprüft und entspricht den Qualitätsstandards der DEKRA.
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="info-card-icon flex-shrink-0" style="width:38px;height:38px;"><Icon name="BadgeCheck" size={18} strokeWidth={1.8} /></span>
              <div>
                <strong class="text-ink font-headline block mb-1">Einhaltung der Herstellervorgaben</strong>
                Wir arbeiten konsequent nach Automobilhersteller-Standards - eine grundlegende Anforderung in unserer Werkstatt.
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="info-card-icon flex-shrink-0" style="width:38px;height:38px;"><Icon name="Award" size={18} strokeWidth={1.8} /></span>
              <div>
                <strong class="text-ink font-headline block mb-1">3 Jahre Garantie auf Lackierarbeiten</strong>
                Wir stehen für unsere Arbeit ein - mit verbindlicher, schriftlicher Garantie.
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Equipment-Grid -->
  <section class="section">
    <div class="container-rd">
      <div class="max-w-3xl mb-10">
        <p class="eyebrow mb-5"><span>Moderne Technik</span></p>
        <h2 class="heading-xl text-balance mb-4">
          Ausstattung nach <span class="accent-brand">aktuellem Stand der Lackreparatur-Technik.</span>
        </h2>
        <p class="lead text-pretty">
          Wir setzen auf fach- und zeitgerechte Qualifikation unserer Mitarbeiter sowie eine moderne Ausstattung, die einen reproduzierbar hohen Qualitätsstandard erlaubt.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
        {equipment.map((e, i) => (
          <div class={`info-card fade-in stagger-${(i % 6) + 1}`}>
            <span class="info-card-icon">
              <Icon name={e.icon} size={22} strokeWidth={1.8} />
            </span>
            <h3 class="heading-md mb-1">{e.title}</h3>
            <p class="text-ink-soft text-pretty">{e.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Umwelt-Block -->
  <section class="section-sm section-paper-deep">
    <div class="container-rd">
      <div class="max-w-4xl mx-auto p-8 md:p-10 rounded-2xl bg-white border border-line">
        <div class="flex items-start gap-4">
          <span class="info-card-icon flex-shrink-0" style="background:linear-gradient(135deg,rgb(214 40 40 / 0.15),rgb(214 40 40 / 0.05));border-color:rgb(214 40 40 / 0.25);color:rgb(var(--rgb-accent));">
            <Icon name="Shield" size={22} strokeWidth={1.8} />
          </span>
          <div>
            <h3 class="heading-md mb-2">Umwelt &amp; Arbeitsschutz</h3>
            <p class="text-ink-soft text-pretty">
              Unsere Werkstatt erfüllt die geltenden Umweltanforderungen und Arbeitsschutzrichtlinien vollständig. Wir verwenden ausschließlich geprüfte Qualitätsprodukte von PPG und Glasurit - regelmäßig geprüft und nach Herstellervorgaben verarbeitet.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="final-cta">
    <div class="final-cta-bg" aria-hidden="true">
      <img src="/images/hero.jpg" alt="" loading="lazy" />
      <div class="final-cta-overlay"></div>
    </div>
    <div class="container-rd relative">
      <div class="final-cta-inner">
        <h2 class="heading-display text-white text-balance mb-5">
          Fragen zur <span style="color:rgb(var(--rgb-brand-sky));">Qualität?</span>
        </h2>
        <p class="lead-on-dark max-w-2xl mx-auto mb-8 text-pretty">
          Rufen Sie an - wir zeigen Ihnen gerne unsere Halle und erklären Ihnen unsere Arbeitsweise persönlich.
        </p>
        <a href={telLandline} class="btn btn-primary btn-lg">
          <Icon name="Phone" size={16} strokeWidth={2.2} />
          {site.phoneLandline}
        </a>
      </div>
    </div>
  </section>

</Layout>
