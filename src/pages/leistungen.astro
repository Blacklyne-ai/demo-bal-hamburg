---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { site, telLandline } from '../data/site';
import { services, faqs } from '../data/services';

const groups = [
  { cat: 'Lackierung', label: 'Lackierung', text: 'Vom Spot-Repair bis zur Komplettlackierung - in moderner Lackier- und Trockenkabine mit kurzwelliger Infrarot-Trocknung.' },
  { cat: 'Karosserie', label: 'Karosserie', text: 'Richtbankarbeiten, Dellenbeseitigung, Karosserieabteilung mit drei Vorbereitungsplätzen.' },
  { cat: 'Service',    label: 'Service',    text: 'Scheiben-Reparatur, Hohlraumversiegelung, Hol- &amp; Bringservice, Ersatzwagen.' },
];
---

<Layout title={`Leistungen - ${site.name}`} description="Lackierung, Karosserie und Service in einer Halle: Ganzlackierung, Spot Repair, Richtbankarbeiten, Scheibenreparatur, Hohlraumversiegelung und mehr." current="leistungen">

  <!-- Sub-Hero -->
  <section class="pt-32 pb-12 md:pt-36 md:pb-16">
    <div class="container-rd">
      <div class="max-w-3xl">
        <p class="eyebrow mb-5">
          <span>Unsere Leistungen</span>
        </p>
        <h1 class="heading-display text-balance mb-5">
          Lackierung, Karosserie, Scheiben - <span class="accent-brand">aus einer Halle.</span>
        </h1>
        <p class="lead text-pretty">
          Vom Kleinschaden bis zur Komplettlackierung Ihres LKW: 2.000 qm Halle, moderne Lackier- &amp; Trockenkabine, 12 Vorbereitungsplätze und 20+ geschulte Mitarbeiter. Wir arbeiten an Fahrzeugen bis 7,5 Tonnen.
        </p>
      </div>
    </div>
  </section>

  <!-- Gruppen-Intro -->
  <section class="section-sm section-paper-deep">
    <div class="container-rd">
      <div class="grid md:grid-cols-3 gap-6">
        {groups.map((g) => (
          <div class="p-6 rounded-2xl bg-white border border-line">
            <p class="eyebrow mb-3"><span>{g.label}</span></p>
            <p class="text-ink-soft text-pretty" set:html={g.text}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Alle Services im Detail -->
  <section class="section">
    <div class="container-rd">
      <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-6">
        {services.map((s, i) => (
          <article class={`info-card fade-in stagger-${(i % 8) + 1}`}>
            <span class="info-card-icon">
              <Icon name={s.iconName} size={24} strokeWidth={1.8} />
            </span>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand mb-1">{s.category}</p>
            <h3 class="heading-md mb-2">{s.title}</h3>
            <p class="text-ink-soft text-pretty">{s.long}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Industrie- & Möbellackierungen Extra-Block -->
  <section class="section-sm section-paper-deep">
    <div class="container-rd">
      <div class="max-w-4xl p-8 md:p-10 rounded-2xl bg-white border border-line">
        <div class="flex items-start gap-4">
          <span class="info-card-icon flex-shrink-0">
            <Icon name="Sparkles" size={24} strokeWidth={1.8} />
          </span>
          <div>
            <h3 class="heading-md mb-2">Industrie- &amp; Möbellackierungen</h3>
            <p class="text-ink-soft text-pretty">
              Nicht nur Fahrzeuge: Wir lackieren auch industrielle Bauteile und Möbel im Auftragsbetrieb. Sprechen Sie uns auf Ihr individuelles Projekt an.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container-rd">
      <div class="max-w-3xl mb-10">
        <p class="eyebrow mb-5"><span>Häufige Fragen</span></p>
        <h2 class="heading-xl text-balance">Antworten auf <span class="accent-brand">die gängigsten Fragen.</span></h2>
      </div>

      <div class="max-w-3xl">
        {faqs.map((f) => (
          <details class="border-b border-line py-1 group">
            <summary class="cursor-pointer py-4 list-none flex items-start justify-between gap-4 font-headline font-bold text-lg text-ink hover:text-brand transition">
              <span>{f.q}</span>
              <span class="flex-shrink-0 mt-1 text-ink-muted group-open:rotate-180 transition">
                <Icon name="ChevronDown" size={20} strokeWidth={2} />
              </span>
            </summary>
            <p class="text-ink-soft pb-5 leading-relaxed text-pretty">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="final-cta">
    <div class="final-cta-bg" aria-hidden="true">
      <img src="/images/hero.jpg" alt="" loading="lazy" />
      <div class="final-cta-overlay"></div>
    </div>
    <div class="container-rd relative">
      <div class="final-cta-inner">
        <h2 class="heading-display text-white text-balance mb-5">
          Brauchen Sie eine <span style="color:rgb(var(--rgb-brand-sky));">Einschätzung?</span>
        </h2>
        <p class="lead-on-dark max-w-2xl mx-auto mb-8 text-pretty">
          Rufen Sie uns kurz an - wir besprechen Ihr Anliegen und schauen, was sich für Ihr Fahrzeug am besten lohnt.
        </p>
        <a href={telLandline} class="btn btn-primary btn-lg">
          <Icon name="Phone" size={16} strokeWidth={2.2} />
          {site.phoneLandline}
        </a>
      </div>
    </div>
  </section>

</Layout>
