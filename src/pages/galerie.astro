---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { site, telLandline } from '../data/site';

const gallery = [
  { src: '/images/lackier-1.jpg',     caption: 'Hochwertige Lackierarbeiten' },
  { src: '/images/karosserie-1.jpg',  caption: 'Karosseriearbeiten' },
  { src: '/images/felgen-1.jpg',      caption: 'Felgenlackierungen' },
  { src: '/images/galerie-01.jpg',    caption: 'Werkstatt-Detail' },
  { src: '/images/galerie-hero.jpg',  caption: 'Blick in die Halle' },
  { src: '/images/hero.jpg',          caption: 'Außenansicht Bergedorf' },
  { src: '/images/philosophie.jpg',   caption: 'Werkstattalltag' },
  { src: '/images/qualitaet.jpg',     caption: 'Arbeitsplatz' },
  { src: '/images/leistungen.jpg',    caption: 'Lackier-Atmosphäre' },
];
---

<Layout title={`Galerie - ${site.name}`} description="Eindrücke aus unserer 2.000 qm Halle in Hamburg-Bergedorf: Lackierarbeiten, Karosserie, Felgen und Werkstatt-Atmosphäre." current="galerie">

  <!-- Sub-Hero mit Banner -->
  <section class="subpage-hero">
    <div class="subpage-hero-bg" aria-hidden="true">
      <img src="/images/galerie-header.jpg" alt="" loading="eager" />
      <div class="subpage-hero-overlay"></div>
    </div>
    <div class="subpage-hero-inner">
      <div class="container-rd">
        <div class="max-w-3xl">
          <p class="eyebrow mb-5" style="color:rgb(var(--rgb-brand-sky));"><span>Galerie</span></p>
          <h1 class="heading-display text-balance mb-5">
            Eindrücke aus unserer <span style="color:rgb(var(--rgb-brand-sky));">Werkstatt.</span>
          </h1>
          <p class="lead-on-dark max-w-2xl text-pretty">
            Hochwertige Lackierarbeiten, präzise Karosserie und sauberer Werkstattalltag - ein Blick in unsere 2.000 qm Halle in Hamburg-Bergedorf.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Grid (3x3) -->
  <section class="pb-20">
    <div class="container-rd">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5">
        {gallery.map((g, i) => (
          <div class={`gallery-tile fade-in stagger-${(i % 9) + 1}`}>
            <img src={g.src} alt={g.caption} loading={i < 3 ? 'eager' : 'lazy'} />
            <span class="gallery-caption">{g.caption}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="final-cta">
    <div class="final-cta-bg" aria-hidden="true">
      <img src="/images/karosserie-1.jpg" alt="" loading="lazy" />
      <div class="final-cta-overlay"></div>
    </div>
    <div class="container-rd relative">
      <div class="final-cta-inner">
        <h2 class="heading-display text-white text-balance mb-5">
          Selbst <span style="color:rgb(var(--rgb-brand-sky));">vor Ort vorbeischauen?</span>
        </h2>
        <p class="lead-on-dark max-w-2xl mx-auto mb-8 text-pretty">
          Wir zeigen Ihnen gerne unsere Halle und die Arbeitsbereiche. Rufen Sie kurz an und vereinbaren Sie einen Termin.
        </p>
        <a href={telLandline} class="btn btn-primary btn-lg">
          <Icon name="Phone" size={16} strokeWidth={2.2} />
          {site.phoneLandline}
        </a>
      </div>
    </div>
  </section>

</Layout>
